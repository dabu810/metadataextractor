# ── Stage 1: builder ───────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /build

COPY requirements.kg.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.kg.txt


# ── Stage 2: runtime ───────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

LABEL maintainer="metadata-agent" \
      description="Knowledge Graph Agent — FastAPI microservice for Cypher/Gremlin generation"

RUN groupadd -r agent && useradd -r -g agent agent

WORKDIR /app

COPY --from=builder /install /usr/local

# Copy the knowledge_graph_agent package and FastAPI entry-point
COPY knowledge_graph_agent/ /app/knowledge_graph_agent/
COPY kg_api.py              /app/kg_api.py

RUN chown -R agent:agent /app

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

USER agent

EXPOSE 8002

HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/health')"

CMD ["uvicorn", "kg_api:app", \
     "--host", "0.0.0.0", \
     "--port", "8002", \
     "--workers", "1", \
     "--log-level", "info"]
