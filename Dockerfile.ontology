# ── Stage 1: builder ───────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /build

COPY requirements.ontology.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.ontology.txt


# ── Stage 2: runtime ───────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

LABEL maintainer="metadata-agent" \
      description="Ontology Agent — FastAPI microservice for OWL/RDF generation"

RUN groupadd -r agent && useradd -r -g agent agent

WORKDIR /app

COPY --from=builder /install /usr/local

# Copy the ontology_agent package
COPY ontology_agent/ /app/ontology_agent/

# Copy the FastAPI entry-point
COPY ontology_api.py /app/ontology_api.py

# Data volume — ontology files are written here
RUN mkdir -p /data/reports && chown -R agent:agent /data /app
VOLUME ["/data/reports"]

ENV PYTHONPATH=/app \
    DATA_DIR=/data/reports \
    PYTHONUNBUFFERED=1

USER agent

EXPOSE 8001

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/health')"

CMD ["uvicorn", "ontology_api:app", \
     "--host", "0.0.0.0", \
     "--port", "8001", \
     "--workers", "1", \
     "--log-level", "info"]
